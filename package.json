{
  "name": "engineer-blog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "velite --watch & next dev",
    "build": "velite && next build",
    "start": "next start",
    "lint": "prettier --check . && eslint && markdownlint-cli2 \"content/**/*.mdx\"",
    "format": "prettier --write . && eslint --fix && markdownlint-cli2 --fix \"content/**/*.mdx\"",
    "velite": "velite",
    "update": "npx npm-check-updates -u --reject eslint-plugin-mdx,markdownlint-cli2 && npm install --legacy-peer-deps && npm audit fix --legacy-peer-deps"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-syntax-highlighter": "^16.1.1",
    "remark-breaks": "^4.0.0",
    "tailwind-merge": "^3.5.0",
    "velite": "^0.3.1"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "eslint": "^10",
    "eslint-config-prettier": "^10",
    "eslint-plugin-mdx": "^2.0.5",
    "markdownlint-cli2": "^0.21.0",
    "postcss": "^8",
    "prettier": "^3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
