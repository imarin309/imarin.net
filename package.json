{
  "name": "engineer-blog",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "prettier --check . && eslint && markdownlint-cli2 \"content/**/*.mdx\"",
    "format": "prettier --write . && eslint --fix && markdownlint-cli2 --fix \"content/**/*.mdx\"",
    "update": "pnpm dlx npm-check-updates -u --reject eslint-plugin-mdx,markdownlint-cli2 && pnpm install"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.4",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.7.0",
    "mermaid": "^11.13.0",
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-syntax-highlighter": "^16.1.1",
    "remark-breaks": "^4.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "unist-util-visit": "^5.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/mdast": "^4.0.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "eslint": "^10",
    "eslint-config-prettier": "^10",
    "eslint-plugin-mdx": "^2.0.5",
    "markdownlint-cli2": "^0.21.0",
    "postcss": "^8",
    "prettier": "^3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "unified": "^11.0.5"
  }
}
